{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"assist": {
		"enabled": true
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/.next",
			"!**/.playwright-state",
			"!**/coverage",
			"!**/dist-tests",
			"!**/node_modules",
			"!**/playwright-report",
			"!**/test-results",
			"!public/models"
		]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true
	}
}

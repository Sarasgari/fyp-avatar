OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALLOWED_ORIGINS=http://localhost:3000
SESSION_SIGNING_SECRET=replace-with-a-long-random-secret
# In production, ALLOWED_ORIGINS and SESSION_SIGNING_SECRET are now enforced at runtime.
# Optional: customize the signed guest-session cookie
# SESSION_COOKIE_NAME=avatar_session
# SESSION_COOKIE_MAX_AGE_SECONDS=2592000
# Optional: customize account auth cookies and signing
# AUTH_SIGNING_SECRET=replace-with-a-separate-long-random-secret
# AUTH_COOKIE_NAME=avatar_auth
# AUTH_COOKIE_MAX_AGE_SECONDS=2592000
# Optional: shared rate limiting via Upstash Redis REST
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# RATE_LIMIT_PREFIX=fyp-avatar
# Optional: persist saved conversations in Upstash Redis instead of process memory
# THREAD_STORE_PREFIX=fyp-avatar
# THREAD_STORE_TTL_SECONDS=2592000
# Optional: persist user accounts in Upstash Redis instead of process memory
# USER_STORE_PREFIX=fyp-avatar

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALLOWED_ORIGINS=http://localhost:3000
SESSION_SIGNING_SECRET=replace-with-a-long-random-secret
# In production, ALLOWED_ORIGINS and SESSION_SIGNING_SECRET are now enforced at runtime.
# Optional: customize the signed guest-session cookie
# SESSION_COOKIE_NAME=avatar_session
# SESSION_COOKIE_MAX_AGE_SECONDS=2592000
# Optional: customize account auth cookies and signing
# AUTH_SIGNING_SECRET=replace-with-a-separate-long-random-secret
# AUTH_COOKIE_NAME=avatar_auth
# AUTH_COOKIE_MAX_AGE_SECONDS=2592000
# Optional: shared rate limiting via Upstash Redis REST
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# RATE_LIMIT_PREFIX=fyp-avatar
# Optional: guest users can send this many valid messages per 24 hours
# GUEST_CHAT_DAILY_LIMIT=5
# Optional: comma-separated admin emails allowed to view visitor analytics in production
# ADMIN_EMAILS=you@example.com
# Optional: persist saved conversations in Upstash Redis instead of process memory
# THREAD_STORE_PREFIX=fyp-avatar
# THREAD_STORE_TTL_SECONDS=2592000
# Optional: persist user accounts in Upstash Redis instead of process memory
# USER_STORE_PREFIX=fyp-avatar
# Optional: namespace password reset codes in Upstash Redis
# PASSWORD_RESET_PREFIX=fyp-avatar
# Optional: send password reset codes by email through Resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=Avatar Assistant <noreply@yourdomain.com>
# Optional: tune OpenAI text-to-speech voice style
# TTS_VOICE=shimmer
# TTS_SPEED=1.08
# TTS_INSTRUCTIONS=Speak in a cute, playful, friendly style with bright warmth and gentle enthusiasm.
# Optional: use ElevenLabs for avatar speech instead of OpenAI TTS
# ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ELEVENLABS_VOICE_ID=your_voice_id
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
